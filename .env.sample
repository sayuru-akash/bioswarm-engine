# Core provider keys
FIREWORKS_API_KEY=
EXA_API_KEY=
OPENAI_API_KEY=
OLLAMA_API_KEY=

# Runtime paths and limits
DATABASE_PATH=bioswarm.db
OUTPUT_DIR=outputs
RATE_LIMIT_RPM=60
BIOSWARM_DEPTH=2
RUST_LOG=info

# Backend-flexible runtime selection
BIOSWARM_BACKEND=fireworks
BIOSWARM_MODEL=accounts/fireworks/models/kimi-k2-instruct
BIOSWARM_API_BASE_URL=https://api.fireworks.ai/inference/v1
BIOSWARM_API_KEY_ENV=FIREWORKS_API_KEY
