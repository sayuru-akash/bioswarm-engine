# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Environment files with sensitive data
.env
.env.local
.env.*.local
.env.production
.env.development

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Test outputs
*.log
/tmp/*.md
/tmp/*.json
/tmp/*.txt

# Local runtime data
bioswarm.db
*.db
*.sqlite
*.sqlite3

# OS files
Thumbs.db

# Build artifacts
*.o
*.so
*.dylib
*.dll

# Package files
*.tar.gz
*.zip

# Coverage reports
coverage/
*.lcov

# Documentation build
target/doc/

# Benchmark results
criterion/
target/criterion/